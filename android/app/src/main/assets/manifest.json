{
  "manifest_version": 3,
  "name": "Loxley Orbit Bubble Puzzle",
  "version": "1.2",
  "description": "A cute fantasy bubble puzzle game. Match 4 or more bubbles to score big! Plays perfectly offline.",
  "action": {
    "default_title": "Play Loxley Orbit Bubble Puzzle",
    "default_icon": {
      "16": "icons/icon-192.png",
      "48": "icons/icon-192.png",
      "128": "icons/icon-512.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-192.png",
    "48": "icons/icon-192.png",
    "128": "icons/icon-512.png"
  }
}
